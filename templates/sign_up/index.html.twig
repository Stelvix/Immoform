{% extends 'base.html.twig' %}

{% block title %}
    Créer un compte | Immoform
{% endblock %}

{% block body %}
    <style>
    body { background-color: #f8f9fa; }
    .card-signup {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-top: 50px;
    }
    .card-header {
        background-color: #0d6efd;
        color: white;
        border-radius: 15px 15px 0 0 !important;
        text-align: center;
        padding: 20px;
    }
    .btn-primary {
        border-radius: 8px;
        padding: 10px;
        font-weight: bold;
        transition: all 0.3s;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(13, 110, 253, 0.3); }
    .form-control { border-radius: 8px; padding: 12px; border: 1px solid #dee2e6; }
    .form-control:focus { box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1); }
    .alert { border-radius: 10px; border: none; }
</style>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">

                {# Gestion des messages Flash #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
                <div class="card card-signup">
                    <div class="card-header">
                        <h3 class="mb-0">
                            Inscription
                        </h3>
                        <small>
                            Rejoignez le réseau Immoform
                        </small>
                    </div>
                    <div class="card-body p-4">
                        {{ form_start(form) }}
                        <div class="row">
                            <div class="col-6 mb-3">
                                {{ form_label(form.name, 'Prénom') }}
                                {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Jean' }}
                                ) }}
                            </div>
                            <div class="col-6 mb-3">
                                {{ form_label(form.lname, 'Nom') }}
                                {{ form_widget(form.lname, {'attr': {'class': 'form-control', 'placeholder': 'Dupont' }}
                                ) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.email, 'Adresse E-mail') }}
                            {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'nom@exemple.com' }}
                            ) }}
                            <small class="text-muted">
                                Nous vérifierons si votre email est autorisé.
                            </small>
                        </div>

                        <div class="mb-4">
                            {{ form_label(form.password, 'Mot de passe') }}
                            {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': '••••••••' }}
                            ) }}
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus me-2"></i>
                                Créer mon compte
                            </button>
                        </div>
                        {{ form_end(form) }}

                        <hr class="my-4 text-muted">

                            <div class="text-center">
                                <p class="mb-2 text-muted">
                                    Déjà inscrit ?
                                </p>
                                <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold text-primary">
                                    Se connecter ici
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-4 mb-5">
                        <a href="{{ path('app_home') }}" class="text-secondary text-decoration-none small">
                            <i class="fas fa-arrow-left me-1"></i>
                            Retour à l'accueil
                        </a>
                    </div>

                </div>
            </div>
        </div>
    {% endblock %}
