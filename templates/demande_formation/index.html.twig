{% extends 'base.html.twig' %}

{% block title %}
    Demande de Formation | Immoform
{% endblock %}

{% block body %}
    {% include 'Menu/_menu.html.twig' %}

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">

                {# Messages flash #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                <div class="card card-signup mt-5">
                    <div class="card-header text-center">
                        <h3>
                            Demande de Formation
                        </h3>
                        <small>
                            Soumettez votre demande et nous vous contacterons rapidement
                        </small>
                    </div>
                    <div class="card-body p-4">
                        {{ form_start(form) }}

                        <div class="mb-3">
                            {{ form_label(form.agenceID) }}
                            {{ form_widget(form.agenceID, {'attr': {'class': 'form-control' }}
                            ) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.objet) }}
                            {{ form_widget(form.objet, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Formation C# et .NET Core' }}
                            ) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.typeFormation) }}
                            {{ form_widget(form.typeFormation, {'attr': {'class': 'form-control', 'placeholder': 'Technique, Management...' }}
                            ) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.descriptionBesoins) }}
                            {{ form_widget(form.descriptionBesoins, {'attr': {'class': 'form-control', 'placeholder': 'Décrivez vos besoins...' }}
                            ) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.nombreParticipants) }}
                                {{ form_widget(form.nombreParticipants, {'attr': {'class': 'form-control' }}
                                ) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.dateSouhaitee) }}
                                {{ form_widget(form.dateSouhaitee, {'attr': {'class': 'form-control' }}
                                ) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.statutDemande) }}
                                {{ form_widget(form.statutDemande) }}
                            </div>

                        </div>

                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#staticBackdrop">
                                Confirmer la demande
                            </button>
                        </div>

                        <div class="modal fade" id="staticBackdrop" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h1 class="modal-title fs-5" id="staticBackdropLabel">
                                            Modal title
                                        </h1>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body">
                                        <p>
                                            Voulez vous confirmer cette demande?
                                        </p>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                                            <i class="fa-solid fa-ban fa-shake" style="color: rgb(255, 255, 255);"></i>

                                            Annuler
                                        </button>

                                        <button type="submit" class="btn btn-primary " data-bs->
                                            <i class="fa-solid fa-circle-check fa-shake" style="color: rgb(255, 255, 255);"></i>
                                            Confirmer
                                        </button>

                                    </div>
                                </div>
                            </div>
                        </div>

                        {{ form_end(form) }}

                        <hr class="my-4 text-muted">

                            <div class="text-center">
                                <a href="{{ path('app_welcome') }}" class="text-secondary small text-decoration-none">
                                    <i class="fas fa-arrow-left me-1"></i>
                                    Retour à l'accueil
                                </a>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        <!-- Button trigger modal -->

        <!-- Modal -->

        </div>
    {% endblock %}
